rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    // Termíny workshopu - verejne čitateľné (aby si ich videla registrácia).
    // Vytvárať/mazať termíny alebo meniť dátum/kapacitu môže len admin.
    // Verejný registračný formulár smie meniť LEN pole "booked" (počet
    // obsadených miest) pri zápise nového účastníka.
    match /terms/{termId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['booked','waitlistCount']);
    }

    // Registrácie - dokument ID je tajný 5-miestny kód účastníka.
    // - "create" pri registrácii môže robiť ktokoľvek (verejný formulár).
    // - "get" (čítanie JEDNÉHO konkrétneho dokumentu) je povolené komukoľvek,
    //   kto POZNÁ presný kód - kód teda funguje ako heslo. Bez znalosti kódu
    //   sa nedá k záznamu dostať.
    // - "list" (vypísanie VŠETKÝCH registrácií, napr. v admin zóne) je povolené
    //   iba prihlásenému adminovi.
    // - "update" bez admin prihlásenia je obmedzené len na polia, ktoré si
    //   účastník smie meniť sám cez svoj kód (kvízy, zrušenie/presun, feedback).
    //   Osobné údaje, interné poznámky a prezenciu smie meniť len admin.
    match /registrations/{code} {
      allow create: if request.resource.data.keys().hasAll(
                      ['fullName','city','email','phone','termId','survey','createdAt']
                    );
      allow get: if true;
      allow list: if isAdmin();
      allow update: if isAdmin() ||
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['entryQuizDone','exitQuizDone','entryScore','exitScore','entryAnswers','exitAnswers','status','termId','feedback','blockedChangeAttempt']);
      allow delete: if isAdmin();
    }

    // Otázky vstupného/výstupného kvízu (dokumenty "entry" a "exit").
    // Verejne čitateľné (potrebuje ich kviz.html), upravovať ich môže len admin.
    match /quizQuestions/{setId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Nastavenia (text emailu, obsah úvodnej stránky) - verejne čitateľné,
    // upravovať ich môže len admin.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Interný log zmien - čítať ho môže len admin. Zapisovať môže admin
    // čokoľvek; účastník (bez prihlásenia) smie zapísať LEN záznam o svojom
    // prihlásení kódom alebo o zablokovanom pokuse o zmenu/zrušenie tesne
    // pred workshopom - obe majú presne definovaný, neškodný tvar.
    match /auditLog/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin() ||
                      (request.resource.data.action in ['login', 'blocked-change-attempt'] &&
                       request.resource.data.keys().hasOnly(['action','code','details','adminEmail','timestamp']));
    }
  }
}
